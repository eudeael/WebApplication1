@model IEnumerable<WebApplication1.Models.ProfilEmploye>

@{
    ViewBag.Title = "Profils employés";
}

<h2 class="fw-bold mb-3">Profils employés</h2>

<!-- Formulaire de création directement sur la page -->
<div class="card mb-4 shadow-sm">
    <div class="card-header bg-success text-white">Ajouter un employé</div>
    <div class="card-body">
        @using (Html.BeginForm("Create", "ProfilEmploye", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <div class="row mb-2">
                <div class="col">@Html.TextBox("Nom", null, new { @class = "form-control", placeholder = "Nom" })</div>
                <div class="col">@Html.TextBox("Prenom", null, new { @class = "form-control", placeholder = "Prénom" })</div>
                <div class="col">@Html.TextBox("Email", null, new { @class = "form-control", placeholder = "Email" })</div>
            </div>
            <div class="row mb-2">
                <div class="col">@Html.TextBox("Adresse", null, new { @class = "form-control", placeholder = "Adresse" })</div>
                <div class="col">@Html.TextBox("Telephone", null, new { @class = "form-control", placeholder = "Téléphone" })</div>
                <div class="col">@Html.TextBox("DateEmbauche", DateTime.Now.ToString("yyyy-MM-dd"), new { @class = "form-control", type = "date" })</div>
            </div>
            <button type="submit" class="btn btn-success">Ajouter</button>
        }
    </div>
</div>

<!-- Tableau des employés avec actions -->
<table class="table table-hover shadow-sm">
    <thead class="table-primary">
        <tr>
            <th>Nom</th>
            <th>Prénom</th>
            <th>Email</th>
            <th>Téléphone</th>
            <th>Adresse</th>
            <th>Date d'embauche</th>
            <th>Contrat</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var employe in Model)
            {
                <tr>
                    <td>@employe.Nom</td>
                    <td>@employe.Prenom</td>
                    <td>@employe.Email</td>
                    <td>@employe.Telephone</td>
                    <td>@employe.Adresse</td>
                    <td>@employe.DateEmbauche.ToString("dd/MM/yyyy")</td>
                    <td>@employe.TypeContrat</td>
                    <td>
                        <!-- Bouton détails -->
                        @Html.ActionLink("Détails", "Details", new { id = employe.IdProfilEmploye }, new { @class = "btn btn-info btn-sm me-1" })

                        <!-- Formulaire inline pour édition -->
                        @using (Html.BeginForm("Edit", "ProfilEmploye", FormMethod.Post, new { @class = "d-inline" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("IdProfilEmploye", employe.IdProfilEmploye)
                            <button type="submit" class="btn btn-warning btn-sm me-1">Modifier</button>
                        }

                        <!-- Formulaire inline pour suppression -->
                        @using (Html.BeginForm("DeleteConfirmed", "ProfilEmploye", FormMethod.Post, new { @class = "d-inline" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("IdProfilEmploye", employe.IdProfilEmploye)
                            <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center text-muted">Aucun employé trouvé.</td>
            </tr>
        }
    </tbody>
</table>
