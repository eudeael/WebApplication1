            <td>@Html.DisplayFor(modelItem => item.NomDiplome)</td>
            <td>@Html.DisplayFor(modelItem => item.NiveauDiplome)</td>
            <td>@Html.DisplayFor(modelItem => item.Domaine)</td>
            <td>
                @Html.ActionLink("Modifier", "Edit", new { id = item.IdDiplome }) |
                @Html.ActionLink("Dťtails", "Details", new { id = item.IdDiplome })
            </td>
        </tr>
    }
    </table>