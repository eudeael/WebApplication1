@model IEnumerable<WebApplication1.Models.ViewModels.EmployeListItemVM>
@{
    ViewBag.Title = "Liste des employķs";
}
<h2 class="fw-bold mb-3">Employķs</h2>

<table class="table table-hover align-middle shadow-sm">
    <thead class="table-primary">
        <tr>
            <th>Nom</th>
            <th>Prķnom</th>
            <th>┬ge</th>
            <th>Date d'entrķe</th>
            <th>Anciennetķ</th>
            <th>Adresse</th>
            <th>Poste</th>
            <th>Niveau</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.Nom</td>
                <td>@e.Prenom</td>
                <td>@e.Age</td>
                <td>@e.DateEntree.ToString("d")</td>
                <td>@e.Anciennete</td>
                <td>@e.Adresse</td>
                <td>@e.Poste</td>
                <td>@e.Niveau</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary rounded-pill" href="@Url.Action("Emplois","InfoRH", new { id = e.Id })">Offres compatibles</a>
                </td>
            </tr>
        }
    </tbody>
</table>